package components

import (
	"go-tv/internal/channel"
	"time"
)

templ VideoList(sets []channel.Playlist, active channel.Source, activeAt time.Duration) {
	if len(sets) == 0 {
		<ul id="video-list">
			<li id="status" class="text-muted">No items in schedule.</li>
		</ul>
	} else {
		<ul id="video-list">
			for _, set := range sets {
				@SetGroup(set, active, activeAt)
			}
		</ul>
	}
}

templ Editor(sets []channel.Playlist, active channel.Source, activeAt time.Duration) {
	@Layout("go-tv / edit") {
		<body class="editor">
			<header>
				<h1>go-tv</h1>
				<nav>
					<a href="/">Resume</a>
				</nav>
			</header>
			@VideoList(sets, active, activeAt)
			<script src="/editor.js"></script>
		</body>
	}
}
