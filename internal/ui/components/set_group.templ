package components

import (
	"go-tv/internal/channel"
	"time"
)

templ SetGroup(set channel.Playlist, active channel.Source, activeAt time.Duration) {
	{{ isActiveSet := false; for _, v := range set.Videos { if v.Source.Equal(active) { isActiveSet = true; break } } }}
	<li class={ "set-item collapsed", templ.KV("active-set", isActiveSet) }>
		<div class="set-header">
			<div class="handle text-faint" title="drag to reorder">⠿</div>
			<button class="set-toggle" title="collapse/expand" onclick="this.closest('.set-item').classList.toggle('collapsed')">▶</button>
			<input
				class="set-name-input"
				type="text"
				name="name"
				value={ set.Name }
				hx-post="/api/schedule/rename"
				hx-trigger="input changed delay:800ms"
				hx-include="next [name='old_name']"
				hx-swap="none"
				hx-on::after-request="if(event.detail.successful) this.nextElementSibling.value=this.value"
				onmousedown="event.stopPropagation()"
			/>
			<input type="hidden" name="old_name" value={ set.Name }/>
		</div>
		<ul class="set-videos" id={ "set-videos-" + set.Name }>
			for _, v := range set.Videos {
				@VideoCard(v, v.Source.Equal(active), activeAt)
			}
		</ul>
	</li>
}
